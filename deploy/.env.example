MODE=paper
# Live trading gate - keep false until exchange credentials are verified
LIVE_TRADING_ENABLED=false
# Separate IBKR live gate - keep false unless US equity live execution is intended
IBKR_LIVE_TRADING_ENABLED=false
EXCHANGE_API_KEY=<<unset>>
EXCHANGE_API_SECRET=<<unset>>
BACKTEST_SERVICE_URL=http://backtest-service:8088
BACKTEST_SERVICE_HOST_PORT=18088
BACKTEST_MAX_BARS=5000
FIXTURES_ONLY=false

# US equity quote source. Polygon Starter ($29/mo) is the recommended
# primary; leave blank to fall back to Yahoo (unofficial, fragile)
# then deterministic fixtures.
POLYGON_API_KEY=
STOCK_QUOTE_CACHE_TTL_SEC=60
STOCK_QUOTE_PROVIDER_CHAIN=ibkr,polygon,yahoo,fixture

# Interactive Brokers paper bridge. IBKR_MODE=stub keeps Phase 20 simulated
# stock fills. Set IBKR_MODE=bridge only after local TWS/Gateway paper mode is
# running and /readyz reports ready.
IBKR_MODE=stub
IBKR_BRIDGE_URL=http://ibkr-bridge:8086
IBKR_BRIDGE_HOST_PORT=18086
IBKR_GATEWAY_HOST=host.docker.internal
IBKR_GATEWAY_PORT=4002
# Safety guard for IBKR live gateway ports 7496/4001. Keep false for paper mode.
IBKR_ALLOW_LIVE_PORT=false
IBKR_CLIENT_ID=1
IBKR_CONNECT_TIMEOUT_SEC=10
IBKR_POLL_TIMEOUT_SEC=60
IBKR_POLL_INTERVAL_SEC=1
# IBKR account code for position subscription (blank = all accounts).
# Reserved for Phase 26 multi-account; Phase 24 subscribes to all.
IBKR_ACCOUNT_CODE=

MAX_NOTIONAL_USDT=10000
CONFIRMATION_THRESHOLD_USDT=500
PER_SYMBOL_DAILY_LIMIT_USDT=50000

# Live trading second gate - short-TTL token issued by POST /admin/live-unlock.
# Uses OPS_TOKEN defined below.
LIVE_UNLOCK_TTL_MIN=15

# Daily PnL hard stop (USDT). When breached, risk-engine rejects further orders.
DAILY_DRAWDOWN_HARD_STOP_USDT=1000

# Scorecard default time-to-live in minutes
SCORECARD_DEFAULT_TTL_MIN=60

# TradingAgents bridge URL (external tradingagents-official hermes_bridge HTTP server)
TA_BRIDGE_URL=http://tradingagents-bridge:18181
TA_DEFAULT_PROVIDER=deepseek
TA_TIMEOUT_SEC=900
ANALYSIS_SCORECARD_TTL_MIN=60

# Outcome reflection retry timeout in seconds
REFLECT_TIMEOUT_SEC=60

# Watchlist scheduler
SCHEDULER_ENABLED=true
SCHEDULER_TICK_SEC=60
SCHEDULER_BATCH_LIMIT=5

# Paper autonomy and calibration
ORCHESTRATOR_SELF_URL=http://localhost:8080
AUTO_TRADE_ENABLED=true
AUTO_TRADE_BATCH_LIMIT=5
CALIBRATION_MIN_SAMPLES=5
CALIBRATION_SHRINKAGE_K=10

# Live autonomy stays off unless deliberately enabled and restarted
LIVE_AUTONOMY_GLOBAL_ENABLED=false
LIVE_AUTO_TICK_SEC=300
LIVE_AUTO_BATCH_LIMIT=1

# Protective watchdog for open scorecard outcomes
STOP_LOSS_WATCHDOG_ENABLED=true
STOP_LOSS_TICK_SEC=60
STOP_LOSS_BATCH_LIMIT=20

# Fill notifications delivered to official Hermes webhook
NOTIFICATION_HOST_ALLOWLIST=hermes-agent,hermes,localhost,127.0.0.1,172.17.0.1,172.23.0.1

# IBKR portfolio reconciliation (Phase 23)
# Average-cost tolerance in USD. Differences smaller than this are treated as
# rounding artifacts from ib_async and ignored. Keep at 0.01 for normal use.
RECONCILE_AVG_COST_TOLERANCE=0.01

# Enables POST /reconcile/ibkr/apply (operator-gated correction).
# Default off - must be explicitly set to "true" to enable writes.
RECONCILE_APPLY_ENABLED=false

# Pre-shared token for X-Ops-Token header. Required when apply is enabled.
OPS_TOKEN=

# Max age of reconcile_log (seconds) before /apply refuses. Default 300.
RECONCILE_MAX_AGE_SECONDS=300
